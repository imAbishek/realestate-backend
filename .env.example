# ============================================================
#  .env.example  —  copy this to .env and fill in your values
#
#  NEVER commit .env to git. It's in .gitignore.
#  This file is safe to commit — it has no real secrets.
# ============================================================

# Spring profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/realestate_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# JWT  —  use a long random string in prod
# generate one: openssl rand -base64 64
# ─────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_very_long_random_secret_key_minimum_32_chars
JWT_ACCESS_EXPIRY=86400000
JWT_REFRESH_EXPIRY=604800000

# ─────────────────────────────────────────────
# AWS S3  (or MinIO for local)
# ─────────────────────────────────────────────
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
AWS_REGION=ap-south-1
S3_BUCKET=realestate-property-images

# ─────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@yoursite.com

# ─────────────────────────────────────────────
# CORS  —  comma-separated list of allowed frontends
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
